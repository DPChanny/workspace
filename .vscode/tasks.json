{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "cppbuild",
      "label": "cppbuild",
      "command": "g++",
      "args": [
        "-g",
        "${file}",
        "-o",
        "${fileDirname}\\${fileBasenameNoExtension}.exe",
        "-std=c++23",
        "-fexec-charset=utf-8"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}
