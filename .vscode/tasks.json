{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "cppbuild",
      "label": "Build C++",
      "command": "clang++",
      "args": [
        "-g",
        "${file}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}.exe",
        "-std=c++23",
        "-fexec-charset=utf-8"
      ],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$gcc"]
    },
    {
      "type": "cppbuild",
      "label": "Build C",
      "command": "clang",
      "args": [
        "-g",
        "${file}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}.exe",
        "-fexec-charset=utf-8"
      ],
      "group": "build",
      "problemMatcher": ["$gcc"]
    },
    {
      "type": "shell",
      "label": "Run C++",
      "command": "Start-Process",
      "args": ["-NoNewWindow", "${fileDirname}/${fileBasenameNoExtension}.exe"],
      "dependsOn": ["Build C++"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "type": "shell",
      "label": "Run C",
      "command": "Start-Process",
      "args": ["-NoNewWindow", "${fileDirname}/${fileBasenameNoExtension}.exe"],
      "dependsOn": ["Build C"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "type": "shell",
      "label": "Run Python",
      "command": "python",
      "args": ["${file}"],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": []
    }
  ]
}
