{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "cppbuild",
      "label": "Build CPP",
      "command": "g++",
      "args": [
        "-g",
        "${file}",
        "-o",
        "${fileDirname}\\${fileBasenameNoExtension}.exe",
        "-std=c++23",
        "-fexec-charset=utf-8"
      ],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$gcc"]
    },
    {
      "type": "cppbuild",
      "label": "Build C",
      "command": "gcc",
      "args": [
        "-g",
        "${file}",
        "-o",
        "${fileDirname}\\${fileBasenameNoExtension}.exe",
        "-fexec-charset=utf-8"
      ],
      "group": "build",
      "problemMatcher": ["$gcc"]
    },
    {
      "type": "shell",
      "label": "Run CPP",
      "command": "Start-Process powershell -ArgumentList '-NoExit', '-Command', \"cd '${fileDirname}'; .\\${fileBasenameNoExtension}.exe\"",
      "dependsOn": ["Build CPP"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "type": "shell",
      "label": "Run C",
      "command": "Start-Process powershell -ArgumentList '-NoExit', '-Command', \"cd '${fileDirname}'; .\\${fileBasenameNoExtension}.exe\"",
      "dependsOn": ["Build C"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    }
  ]
}
